# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# Only the `connectors` package reads these; the swap engines need no credentials.

# ── AWS Athena (Presto) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_STAGING_DIR=s3://your-athena-query-results-bucket/

# ── Snowflake ───────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_WAREHOUSE=B2B_S_WH
SNOWFLAKE_DATABASE=SANDBOX
SNOWFLAKE_SCHEMA=B2B
SNOWFLAKE_ROLE=B2B_ANALYST_PRIVILEGED
# OAuth/Okta via the browser — the only auth method we use.
SNOWFLAKE_AUTHENTICATOR=externalbrowser
